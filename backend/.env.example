# Copy this file to .env and fill in real values. Never commit .env itself.

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskflow_db?schema=public"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN=1d

# CORS - the frontend's origin
CORS_ORIGIN=http://localhost:3000

# AI Assistant (Good to Have) - Google Gemini, free tier available, no credit card required
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
